# --- VLM Provider: anthropic | openai ---
VLM_PROVIDER=anthropic
VLM_MODEL=claude-sonnet-4-6

# Anthropic (for analyze + critic)
ANTHROPIC_API_KEY=

# OpenAI (alternative VLM backend)
OPENAI_API_KEY=

# --- Image-to-Video Provider: stub | luma | fal ---
I2V_PROVIDER=stub
LUMA_API_KEY=
FAL_API_KEY=

# --- Pipeline Knobs ---
QUALITY_THRESHOLD=0.45
MIN_CLIP_SEC=1.5
MAX_CLIP_SEC=6.0
MAX_BAD_CLIPS=10
MIN_GAP_SEC=5.0
