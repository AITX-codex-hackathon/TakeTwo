# --- OpenAI Vision/Language Model ---
OPENAI_API_KEY=
VLM_MODEL=gpt-4o
# For low-tier projects, OpenAI may allow only 1 input image/min.
# Raise these after your project limits increase.
OPENAI_MAX_IMAGES_PER_REQUEST=1
OPENAI_IMAGE_MIN_INTERVAL_SEC=65
OPENAI_SKIP_CRITIC_WHEN_IMAGE_LIMITED=1

# --- Image-to-Video Provider: fal_kling_v21 | fal_luma | fal_kling_v3 | stub ---
I2V_PROVIDER=fal_kling_v21

FAL_API_KEY=
FAL_GENERATION_TIMEOUT_SEC=240
FAL_POLL_INTERVAL_SEC=8
FAL_GENERATIONS_PER_SLOT=2
FAL_MAX_GENERATED_SLOTS=3
FAL_CONCURRENCY=3

# --- Pipeline Knobs ---
QUALITY_THRESHOLD=0.45
MIN_CLIP_SEC=1.5
MAX_CLIP_SEC=6.0
MAX_BAD_CLIPS=10
MIN_GAP_SEC=5.0
